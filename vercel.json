{
  "crons": [
    {
      "path": "/api/cron/send-readings",
      "schedule": "0 13 * * *"
    }
  ],
  "rewrites": [
    { "source": "/portal", "destination": "/portal.html" },
    { "source": "/welcome", "destination": "/welcome.html" },
    { "source": "/birth-chart-form", "destination": "/birth-chart-form.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/unsubscribe", "destination": "/unsubscribe.html" },
    { "source": "/terms", "destination": "/terms.html" }
  ]
}
